{
	"name": "image-generation-benchmarks",
	"version": "0.1.0",
	"private": true,
	"description": "Fair, reproducible benchmarks for JavaScript image generation libraries across runtimes, scenarios, and output formats.",
	"type": "module",
	"scripts": {
		"bench": "node src/runner/bench.ts",
		"bench:quick": "node src/runner/bench.ts --quick",
		"validate": "node src/runner/validate.ts",
		"report": "node src/runner/report.ts",
		"compare": "node src/runner/compare.ts",
		"assets:generate": "node scripts/generate-assets.ts",
		"baselines:update": "node scripts/update-baselines.ts",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check"
	},
	"dependencies": {
		"@napi-rs/canvas": "1.0.2",
		"@resvg/resvg-js": "2.6.2",
		"@resvg/resvg-wasm": "2.6.2",
		"@takumi-rs/core": "2.3.0",
		"@takumi-rs/helpers": "2.3.0",
		"canvas": "3.2.3",
		"canvaskit-wasm": "0.41.1",
		"fast-png": "8.0.0",
		"mitata": "1.0.34",
		"pixelmatch": "7.2.0",
		"pureimage": "0.4.20",
		"satori": "0.28.0",
		"skia-canvas": "3.0.8"
	},
	"devDependencies": {
		"@types/node": "25.9.5",
		"@types/react": "19.2.17",
		"oxfmt": "0.60.0",
		"oxlint": "1.75.0",
		"typescript": "7.0.2"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "pnpm@11.17.0",
	"trustedDependencies": [
		"canvas",
		"skia-canvas"
	]
}
